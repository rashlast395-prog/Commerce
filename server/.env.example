NODE_ENV=development
PORT=8080

# Firebase
FIREBASE_PROJECT_ID=fire-c1a91
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"fire-c1a91",...}
GOOGLE_APPLICATION_CREDENTIALS=

# CORS
ALLOWED_ORIGINS=http://localhost:5501,http://localhost:3000,https://abdulrashidyussif.github.io

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Redis (optional)
REDIS_URL=redis://localhost:6379

# Admin Configuration
ADMIN_EMAIL=rashlast395@gmail.com
ADMIN_NAME=rashlast395-prog

# ---- AI Assistant (Richy) ----
# Server-side ONLY. Never expose to the browser/frontend.
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o-mini
# Optional alias also accepted by the server: AI_API_KEY=your_openai_key_here

# AI endpoint CORS: origins allowed to call /api/ai/chat
ALLOWED_ORIGINS=http://localhost:5501,http://127.0.0.1:5501,https://your-domain.com

# AI endpoint rate limiting (per IP)
RATE_LIMIT_MAX_REQUESTS=20
RATE_LIMIT_WINDOW_MS=60000
