/* ============================================================
   Firestore Security Rules — Richy's Eat
   ------------------------------------------------------------
   Enforces the spec's SECURITY requirements:

   - Customers can ONLY read/write their own documents
     (users/{uid}, users/{uid}/orders, .../notifications, ...).
   - Riders can read all orders they are assigned to, can update
     the delivery status of those orders, and read/write their
     own rider profile.
   - Admins (rashlast395@gmail.com / displayName rashlast395-prog)
     have full read/write across the platform.
   - Anonymous/guest writes are blocked except to guest_orders
     with a server-checked shape (defense in depth; the Node
     server is the real gatekeeper).
   ============================================================ */

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && (request.auth.token.email == 'rashlast395@gmail.com'
            || request.auth.token.name == 'rashlast395-prog');
    }

    function isRider() {
      return request.auth != null
        && exists(/databases/$(database)/documents/riders/$(request.auth.uid))
        && !isAdmin();
    }

    function isSelf(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    function isAssignedRider(orderDoc) {
      return request.auth != null
        && orderDoc.riderId == request.auth.uid;
    }

    /* ---- USERS ---- */
    match /users/{uid} {
      allow read, write: if isAdmin() || isSelf(uid);

      match /orders/{orderId} {
        allow read: if isAdmin() || isSelf(uid);
        allow create, update: if isSelf(uid);
        allow delete: if isSelf(uid);
      }
      match /reservations/{resvId} {
        allow read, write: if isAdmin() || isSelf(uid);
      }
      match /addresses/{addrId} {
        allow read, write: if isAdmin() || isSelf(uid);
      }
      match /notifications/{notifId} {
        allow read: if isAdmin() || isSelf(uid);
        allow create: if isAdmin() || isSelf(uid);
        allow update: if isSelf(uid);
        allow delete: if isSelf(uid);
      }
      match /messages/{msgId} {
        allow read, write: if isAdmin() || isSelf(uid);
      }
    }

    /* ---- TOP-LEVEL ORDERS ---- */
    match /orders/{orderId} {
      allow read: if isAdmin() || isRider() || (request.auth != null && resource.data.uid == request.auth.uid);
      allow create: if isAdmin() || (request.auth != null && request.resource.data.uid == request.auth.uid);
      // Riders may only change deliveryStatus / status along the workflow.
      allow update: if isAdmin()
                    || (isRider() && isAssignedRider(resource.data)
                        && request.resource.data.diff(resource.data).affectedKeys()
                             .hasOnly(['status', 'deliveryStatus', 'lat', 'lng', 'tracking', 'statusHistory', 'assignedAt']))
                    || (request.auth != null && resource.data.uid == request.auth.uid);
      allow delete: if isAdmin();
    }

    /* ---- RESERVATIONS ---- */
    match /reservations/{resvId} {
      allow read: if isAdmin() || (request.auth != null && resource.data.uid == request.auth.uid);
      allow create: if isAdmin() || (request.auth != null && request.resource.data.uid == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    /* ---- MENU (read by all authed; write by admin) ---- */
    match /menu/{itemId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    /* ---- RIDERS ---- */
    match /riders/{riderId} {
      allow read: if isAdmin() || isRider() || (request.auth != null && riderId == request.auth.uid);
      // A rider can update only their own non-identity fields.
      allow update: if isAdmin()
                    || (isRider() && riderId == request.auth.uid
                        && request.resource.data.diff(resource.data).affectedKeys()
                             .hasOnly(['available', 'status', 'lat', 'lng', 'lastSeen', 'currentOrderId', 'phone', 'vehicle', 'license']));
      allow create, delete: if isAdmin();
    }

    /* ---- CONTACT MESSAGES ---- */
    match /contactMessages/{msgId} {
      allow read: if isAdmin();
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }

    /* ---- GUEST ORDERS (defense in depth, server is the gatekeeper) ---- */
    match /guest_orders/{orderId} {
      allow read, write: if request.auth != null;
    }

    /* ---- NOTIFICATIONS (top-level broadcast pool) ---- */
    match /notifications/{notifId} {
      allow read: if isAdmin()
                  || (request.auth != null && resource.data.uid == request.auth.uid)
                  || (request.auth != null && resource.data.riderId == request.auth.uid);
      allow create: if isAdmin() || request.auth != null;
      allow update: if isAdmin()
                    || (request.auth != null && resource.data.uid == request.auth.uid)
                    || (request.auth != null && resource.data.riderId == request.auth.uid);
      allow delete: if isAdmin();
    }

    /* ---- AUDIT / ACTIVITY LOGS (admin only) ---- */
    match /activityLogs/{logId} {
      allow read: if isAdmin();
      allow create: if request.auth != null;
    }
  }
}
