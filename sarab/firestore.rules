rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // HELPER FUNCTIONS
    // ============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email == 'rashlast395@gmail.com' ||
         request.auth.token.name == 'rashlast395-prog');
    }

    function isCustomer(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isRider(uid) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/riders/$(request.auth.uid)) &&
        !isAdmin();
    }

    // ============================================================
    // USERS
    // ============================================================
    match /users/{userId} {
      allow read: if isAuthenticated() &&
        (request.auth.uid == userId || isAdmin());

      allow update: if isAuthenticated() &&
        (request.auth.uid == userId && 
         request.resource.data.keys().hasOnly(['name', 'email', 'phone', 'dob', 'age', 'gender', 'address', 'role', 'customerId', 'orderHistory', 'reservationHistory', 'addresses', 'wishlist', 'rewardPoints', 'notificationSettings', 'updatedAt']) ||
         isAdmin());

      allow create: if isAdmin();
      allow delete: if isAdmin();

      // ============================================================
      // USER SUBCOLLECTIONS
      // ============================================================

      // Orders subcollection (legacy - read-only during transition)
      match /orders/{orderId} {
        allow read: if isAuthenticated() &&
          (request.auth.uid == userId || isAdmin());
        allow write: if false;
      }

      // User's reservations subcollection (legacy - read-only during transition)
      match /reservations/{resvId} {
        allow read: if isAuthenticated() &&
          (request.auth.uid == userId || isAdmin());
        allow write: if false;
      }

      // User's notifications
      match /notifications/{notifId} {
        allow read: if isAuthenticated() && request.auth.uid == userId;
        allow update: if isAuthenticated() && request.auth.uid == userId &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
        allow create: if isAdmin();
        allow delete: if isAdmin();
      }

      // User's addresses
      match /addresses/{addrId} {
        allow read: if isAuthenticated() && request.auth.uid == userId;
        allow write: if isAuthenticated() && request.auth.uid == userId;
      }
    }

    // ============================================================
    // ORDERS COLLECTION (top-level - single source of truth)
    // ============================================================
    match /orders/{orderId} {
      // Read: admin reads all, customer reads own, rider reads assigned
      allow read: if isAuthenticated() &&
        (isAdmin() ||
         resource.data.customerId == request.auth.uid ||
         resource.data.riderId == request.auth.uid ||
         resource.data.riderUid == request.auth.uid);

      // Create: admin or customer creating their own order
      allow create: if isAuthenticated() &&
        (isAdmin() || request.resource.data.customerId == request.auth.uid);

      // Update: admin can update anything, customer can update own limited fields, rider can update assigned order status
      allow update: if isAuthenticated() &&
        (isAdmin() ||
         (resource.data.customerId == request.auth.uid && 
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'deliveryStatus', 'statusHistory', 'tracking', 'updatedAt'])) ||
         (resource.data.riderId == request.auth.uid && 
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'deliveryStatus', 'statusHistory', 'tracking', 'updatedAt'])));

      allow delete: if isAdmin();
    }

    // ============================================================
    // RESERVATIONS COLLECTION (top-level - single source of truth)
    // ============================================================
    match /reservations/{resvId} {
      allow read: if isAuthenticated() && isAdmin();
      allow create: if isAuthenticated() && request.resource.data.customerId == request.auth.uid;
      allow update: if isAuthenticated() &&
        (isAdmin() || resource.data.customerId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // ============================================================
    // RIDERS COLLECTION
    // ============================================================
    match /riders/{riderId} {
      allow read: if isAuthenticated();
      
      allow update: if isAuthenticated() &&
        (request.auth.uid == riderId || isAdmin());
      
      allow create, delete: if isAdmin();
    }

    // ============================================================
    // MENU COLLECTION
    // ============================================================
    match /menu/{itemId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ============================================================
    // CONTACT MESSAGES
    // ============================================================
    match /contactMessages/{msgId} {
      allow read: if isAuthenticated() && isAdmin();
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ============================================================
    // NOTIFICATIONS (global)
    // ============================================================
    match /notifications/{notifId} {
      allow read: if isAuthenticated() && isAdmin();
      allow create: if isAdmin();
      allow update, delete: if isAdmin();
    }

    // ============================================================
    // ACTIVITY LOGS
    // ============================================================
    match /activityLogs/{logId} {
      allow read: if isAuthenticated() && isAdmin();
      allow create: if isAdmin();
      allow update, delete: if isAdmin();
    }

    // ============================================================
    // MESSAGES (user-to-user messaging)
    // ============================================================
    match /messages/{msgId} {
      allow read: if isAuthenticated() &&
        (resource.data.senderId == request.auth.uid || 
         resource.data.receiverId == request.auth.uid ||
         isAdmin());
      allow create: if isAuthenticated() && request.resource.data.senderId == request.auth.uid;
      allow update: if isAuthenticated() &&
        (resource.data.receiverId == request.auth.uid && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']) ||
         isAdmin());
      allow delete: if isAdmin();
    }

    // ============================================================
    // GUEST ORDERS
    // ============================================================
    match /guest_orders/{orderId} {
      allow read, write: if isAdmin();
    }
  }
}
