rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // HELPER FUNCTIONS
    // ============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email == 'rashlast395@gmail.com' ||
         request.auth.token.name == 'rashlast395-prog');
    }

    function isCustomer(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isRider(uid) {
      return isAuthenticated() && request.auth.uid == uid &&
        exists(/databases/$(database)/documents/riders/$(uid));
    }

    function getUserRole(uid) {
      if (isAdmin()) return 'admin';
      if (isRider(uid)) return 'rider';
      return 'customer';
    }

    // ============================================================
    // USERS COLLECTION
    // ============================================================
    match /users/{userId} {
      // Users can read their own profile, admins can read all
      allow read: if isAuthenticated() &&
        (request.auth.uid == userId || isAdmin());

      // Users can update their own profile (limited fields), admins can update any
      allow update: if isAuthenticated() &&
        (request.auth.uid == userId && 
         request.resource.data.keys().hasOnly(['name', 'email', 'phone', 'dob', 'age', 'gender', 'address', 'role', 'customerId', 'orderHistory', 'reservationHistory', 'addresses', 'wishlist', 'rewardPoints', 'notificationSettings', 'updatedAt']) ||
         isAdmin());

      // Only Firebase Auth / server can create users
      allow create: if isAdmin();

      // Only admins can delete users
      allow delete: if isAdmin();

      // ============================================================
      // USER SUBCOLLECTIONS
      // ============================================================

      // User's orders - customers can read their own, admins read all
      match /orders/{orderId} {
        allow read: if isAuthenticated() &&
          (request.auth.uid == userId || isAdmin());
        allow write: if isAdmin() || 
          (request.auth.uid == userId && 
           request.resource.data.keys().hasOnly(['id', 'status', 'deliveryStatus', 'statusHistory', 'items', 'itemLines', 'total', 'method', 'address', 'city', 'zip', 'riderId', 'riderName', 'riderPhone', 'riderVehicle', 'tracking', 'updatedAt']));
      }

      // User's reservations
      match /reservations/{resvId} {
        allow read: if isAuthenticated() &&
          (request.auth.uid == userId || isAdmin());
        allow write: if isAdmin() || 
          (request.auth.uid == userId && 
           request.resource.data.keys().hasOnly(['id', 'status', 'statusHistory', 'name', 'email', 'phone', 'guests', 'date', 'time', 'notes']));
      }

      // User's notifications
      match /notifications/{notifId} {
        allow read: if isAuthenticated() && request.auth.uid == userId;
        allow update: if isAuthenticated() && request.auth.uid == userId &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
        allow create, delete: if isAdmin();
      }

      // User's addresses
      match /addresses/{addrId} {
        allow read: if isAuthenticated() && request.auth.uid == userId;
        allow write: if isAuthenticated() && request.auth.uid == userId;
      }
    }

    // ============================================================
    // ORDERS COLLECTION (top-level)
    // ============================================================
    match /orders/{orderId} {
      // Authenticated users can read orders they're involved with
      allow read: if isAuthenticated() &&
        (isAdmin() ||
         resource.data.uid == request.auth.uid || // customer
         resource.data.riderId == request.auth.uid || // rider
         resource.data.riderUid == request.auth.uid); // rider by uid

      // Only admins can create top-level orders (orders created via WebSocket server)
      allow create: if isAdmin();

      // Status updates must be valid transitions
      allow update: if isAuthenticated() &&
        (isAdmin() ||
         (resource.data.uid == request.auth.uid && 
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'deliveryStatus', 'statusHistory', 'tracking', 'updatedAt'])) ||
         (resource.data.riderId == request.auth.uid && 
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'deliveryStatus', 'statusHistory', 'tracking', 'updatedAt'])));

      allow delete: if isAdmin();
    }

    // ============================================================
    // RESERVATIONS COLLECTION (top-level)
    // ============================================================
    match /reservations/{resvId} {
      allow read: if isAuthenticated() && isAdmin();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() &&
        (isAdmin() || resource.data.uid == request.auth.uid);
      allow delete: if isAdmin();
    }

    // ============================================================
    // RIDERS COLLECTION
    // ============================================================
    match /riders/{riderId} {
      // Everyone authenticated can read rider profiles
      allow read: if isAuthenticated();
      
      // Riders can update their own profile, admins can update any
      allow update: if isAuthenticated() &&
        (request.auth.uid == riderId || isAdmin());
      
      // Only admins can create/delete riders
      allow create, delete: if isAdmin();
    }

    // ============================================================
    // MENU COLLECTION
    // ============================================================
    match /menu/{itemId} {
      // Everyone can read menu
      allow read: if true;
      
      // Only admins can write menu
      allow write: if isAdmin();
    }

    // ============================================================
    // CONTACT MESSAGES
    // ============================================================
    match /contactMessages/{msgId} {
      allow read: if isAuthenticated() && isAdmin();
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ============================================================
    // NOTIFICATIONS (global)
    // ============================================================
    match /notifications/{notifId} {
      allow read: if isAuthenticated() && isAdmin();
      allow create: if isAdmin();
      allow update, delete: if isAdmin();
    }

    // ============================================================
    // ACTIVITY LOGS
    // ============================================================
    match /activityLogs/{logId} {
      allow read: if isAuthenticated() && isAdmin();
      allow create: if isAdmin();
      allow update, delete: if isAdmin();
    }

    // ============================================================
    // AUDIT LOGS
    // ============================================================
    match /auditLogs/{logId} {
      allow read: if isAuthenticated() && isAdmin();
      allow create: if isAdmin();
      allow update, delete: if isAdmin();
    }

    // ============================================================
    // MESSAGES (user-to-user messaging)
    // ============================================================
    match /messages/{msgId} {
      allow read: if isAuthenticated() &&
        (resource.data.senderId == request.auth.uid || 
         resource.data.receiverId == request.auth.uid ||
         isAdmin());
      allow create: if isAuthenticated() && request.resource.data.senderId == request.auth.uid;
      allow update: if isAuthenticated() &&
        (resource.data.receiverId == request.auth.uid && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']) ||
         isAdmin());
      allow delete: if isAdmin();
    }
  }
}
